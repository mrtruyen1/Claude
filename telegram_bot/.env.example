# Lấy từ @BotFather trên Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Lấy từ https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Model Claude sử dụng (mặc định: claude-sonnet-5)
CLAUDE_MODEL=claude-sonnet-5

# Chat ID được phép dùng bot (lấy bằng cách chat /start với bot)
# Nhiều ID cách nhau bởi dấu phẩy. Để trống = không giới hạn (NGUY HIỂM!)
ALLOWED_CHAT_IDS=123456789,987654321

# Lệnh shell được phép chạy (prefix đầu tiên của lệnh)
# Để trống = cho phép tất cả (NGUY HIỂM!)
ALLOWED_COMMANDS=systemctl,df,free,uptime,docker,ls,journalctl,ping,ip,cat,tail,grep,ps

# Timeout chạy lệnh shell (giây)
SHELL_TIMEOUT_SEC=30

# Số lượt hội thoại tối đa lưu lại (mỗi lượt = 1 câu hỏi + 1 trả lời)
MAX_HISTORY_TURNS=20
